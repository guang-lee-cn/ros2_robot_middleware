<?xml version="1.0" ?>
<!-- AMR 机器人模型 — 差分驱动 + LiDAR + IMU + Camera
     Gazebo Harmonic SDF 格式，传感器通过 ros_gz_bridge 桥接到 ROS2 topic -->
<sdf version="1.9">
  <model name="amr">
    <pose>0 0 0.1 0 0 0</pose>

    <!-- ================================================================
         底盘（body）
         ================================================================ -->
    <link name="chassis">
      <pose>0 0 0.15 0 0 0</pose>
      <inertial>
        <mass>20.0</mass>
        <inertia>
          <ixx>0.5</ixx><iyy>0.5</iyy><izz>0.8</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name="chassis_collision">
        <geometry><box><size>0.6 0.4 0.2</size></box></geometry>
      </collision>
      <visual name="chassis_visual">
        <geometry><box><size>0.6 0.4 0.2</size></box></geometry>
        <material>
          <ambient>0.2 0.2 0.2</ambient>
          <diffuse>0.3 0.3 0.8</diffuse>
        </material>
      </visual>

      <!-- =============================================================
           LiDAR (GPU Ray Sensor) — 发布到 /world/warehouse/model/amr/link/chassis/sensor/lidar/scan
           通过 ros_gz_bridge 桥接到 /sensor/lidar (sensor_msgs/LaserScan)
           ============================================================= -->
      <sensor name="lidar" type="gpu_lidar">
        <pose>0.25 0 0.05 0 0 0</pose>
        <always_on>true</always_on>
        <update_rate>10</update_rate>
        <topic>lidar</topic>
        <ray>
          <scan>
            <horizontal>
              <samples>360</samples>
              <resolution>1</resolution>
              <min_angle>-3.14159</min_angle>
              <max_angle>3.14159</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.1</min>
            <max>10.0</max>
            <resolution>0.01</resolution>
          </range>
        </ray>
      </sensor>

      <!-- =============================================================
           IMU — 发布到 /world/warehouse/model/amr/link/chassis/sensor/imu/imu
           通过 ros_gz_bridge 桥接到 /sensor/imu (sensor_msgs/Imu)
           ============================================================= -->
      <sensor name="imu" type="imu">
        <always_on>true</always_on>
        <update_rate>100</update_rate>
        <topic>imu</topic>
        <imu>
          <angular_velocity>
            <x><noise type="gaussian" mean="0" stddev="0.0004"/></x>
            <y><noise type="gaussian" mean="0" stddev="0.0004"/></y>
            <z><noise type="gaussian" mean="0" stddev="0.0004"/></z>
          </angular_velocity>
          <linear_acceleration>
            <x><noise type="gaussian" mean="0" stddev="0.01"/></x>
            <y><noise type="gaussian" mean="0" stddev="0.01"/></y>
            <z><noise type="gaussian" mean="0" stddev="0.01"/></z>
          </linear_acceleration>
        </imu>
      </sensor>

      <!-- =============================================================
           Camera — 发布到 /world/warehouse/model/amr/link/chassis/sensor/camera/image
           通过 ros_gz_bridge 桥接到 /sensor/camera (sensor_msgs/Image)
           ============================================================= -->
      <sensor name="camera" type="camera">
        <pose>0.28 0 0.05 0 1.57 0</pose>  <!-- 面向前方，旋转补偿 -->
        <always_on>true</always_on>
        <update_rate>5</update_rate>
        <topic>camera</topic>
        <camera>
          <horizontal_fov>1.2043</horizontal_fov>  <!-- ~69° -->
          <image>
            <width>640</width>
            <height>480</height>
            <format>R8G8B8</format>
          </image>
          <clip><near>0.1</near><far>10.0</far></clip>
        </camera>
      </sensor>
    </link>

    <!-- ================================================================
         左驱动轮
         ================================================================ -->
    <link name="left_wheel">
      <pose>0 0.25 -0.05 0 0 0</pose>
      <inertial>
        <mass>1.0</mass>
        <inertia><ixx>0.01</ixx><iyy>0.01</iyy><izz>0.01</izz></inertia>
      </inertial>
      <collision name="collision">
        <geometry><cylinder><radius>0.075</radius><length>0.04</length></cylinder></geometry>
      </collision>
      <visual name="visual">
        <geometry><cylinder><radius>0.075</radius><length>0.04</length></cylinder></geometry>
        <material><ambient>0.1 0.1 0.1</ambient><diffuse>0.2 0.2 0.2</diffuse></material>
      </visual>
    </link>

    <link name="right_wheel">
      <pose>0 -0.25 -0.05 0 0 0</pose>
      <inertial>
        <mass>1.0</mass>
        <inertia><ixx>0.01</ixx><iyy>0.01</iyy><izz>0.01</izz></inertia>
      </inertial>
      <collision name="collision">
        <geometry><cylinder><radius>0.075</radius><length>0.04</length></cylinder></geometry>
      </collision>
      <visual name="visual">
        <geometry><cylinder><radius>0.075</radius><length>0.04</length></cylinder></geometry>
        <material><ambient>0.1 0.1 0.1</ambient><diffuse>0.2 0.2 0.2</diffuse></material>
      </visual>
    </link>

    <!-- 差速驱动 joint -->
    <joint name="left_wheel_joint" type="revolute">
      <parent>chassis</parent>
      <child>left_wheel</child>
      <axis><xyz>0 1 0</xyz></axis>
    </joint>

    <joint name="right_wheel_joint" type="revolute">
      <parent>chassis</parent>
      <child>right_wheel</child>
      <axis><xyz>0 1 0</xyz></axis>
    </joint>

    <!-- ================================================================
         差速驱动插件 — 接收 /cmd_vel (geometry_msgs/Twist)
         ================================================================ -->
    <plugin
      filename="gz-sim-diff-drive-system"
      name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.5</wheel_separation>
      <wheel_radius>0.075</wheel_radius>
      <topic>/cmd_vel</topic>
    </plugin>

    <!-- ================================================================
         关节状态发布插件 — 发布 /joint_states
         ================================================================ -->
    <plugin
      filename="gz-sim-joint-state-publisher-system"
      name="gz::sim::systems::JointStatePublisher">
      <joint_name>left_wheel_joint</joint_name>
      <joint_name>right_wheel_joint</joint_name>
    </plugin>
  </model>
</sdf>
