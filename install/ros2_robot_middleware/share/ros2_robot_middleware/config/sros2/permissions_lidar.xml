<?xml version="1.0" encoding="UTF-8"?>
<dds xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
     xsi:noNamespaceSchemaLocation="http://www.omg.org/spec/DDS-SECURITY/20170901/omg_shared_ca_permissions.xsd">
  <permissions>
    <grant name="/lidar">
      <subject_name>/lidar</subject_name>
      <validity><not_before>2025-01-01T00:00:00</not_before>
                <not_after>2030-01-01T00:00:00</not_after></validity>
      <allow_rule>
        <domains><id>0</id></domains>
        <!-- 发布 LiDAR 扫描数据和心跳 -->
        <publish>
          <topics><topic>/sensor/lidar</topic>
                 <topic>/sensor/lidar/heartbeat</topic></topics>
        </publish>
      </allow_rule>
    </grant>
  </permissions>
</dds>
