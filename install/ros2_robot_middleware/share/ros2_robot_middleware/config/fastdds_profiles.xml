<?xml version="1.0" encoding="UTF-8"?>
<!-- Fast-DDS XML Profile for ros2_robot_middleware
     设计原则：
     - Sensor Layer: 低延迟 beseffort + large socket buffer (900KB camera)
     - Fusion/Decision/Actuation: reliable + pre-allocated history
     - 所有 participant: 增加 initialAnnouncements 加速多节点发现
-->
<profiles>
  <!-- ================================================================
       Participant profiles — 控制 DDS discovery 行为
       ================================================================ -->
  <participant profile_name="sensor_participant">
    <rtps>
      <prefix>53.45.4e.53.4f.52.00.00.00.00.00.00.00.00.00.00</prefix>
      <builtin>
        <!-- 增大初始通知次数加速 discovery（multicast 不可靠场景关键参数） -->
        <initialAnnouncements>
          <count>5</count>
        </initialAnnouncements>
        <discovery_config>
          <leaseDuration>
            <sec>10</sec>
          </leaseDuration>
        </discovery_config>
        <metatrafficUnicastLocatorList>
          <locator>
            <udpv4>
              <port>8000</port>
            </udpv4>
          </locator>
        </metatrafficUnicastLocatorList>
      </builtin>
    </rtps>
  </participant>

  <!-- Generic participant for fusion/decision/motor nodes -->
  <participant profile_name="compute_participant">
    <rtps>
      <builtin>
        <initialAnnouncements>
          <count>5</count>
        </initialAnnouncements>
        <discovery_config>
          <leaseDuration>
            <sec>10</sec>
          </leaseDuration>
        </discovery_config>
      </builtin>
    </rtps>
  </participant>

  <!-- ================================================================
       DataWriter QoS profiles — 按 topic 针对性配置
       ================================================================ -->

  <!-- Camera: 900KB payload, best_effort, large socket buffer -->
  <data_writer profile_name="camera_pub">
    <qos>
      <reliability>
        <kind>BEST_EFFORT</kind>
      </reliability>
      <durability>
        <kind>VOLATILE</kind>
      </durability>
      <deadline>
        <period>
          <sec>0</sec>
          <nanosec>0</nanosec>
        </period>
      </deadline>
    </qos>
    <historyMemoryPolicy>PREALLOCATED</historyMemoryPolicy>
    <propertiesPolicy>
      <properties>
        <property>
          <name>socket_buffer_size</name>
          <value>2097152</value> <!-- 2MB socket buffer for 900KB payloads -->
        </property>
      </properties>
    </propertiesPolicy>
  </data_writer>

  <!-- LiDAR: best_effort, low latency -->
  <data_writer profile_name="lidar_pub">
    <qos>
      <reliability>
        <kind>BEST_EFFORT</kind>
      </reliability>
      <durability>
        <kind>VOLATILE</kind>
      </durability>
    </qos>
    <historyMemoryPolicy>PREALLOCATED</historyMemoryPolicy>
  </data_writer>

  <!-- IMU: reliable, small payload, low jitter -->
  <data_writer profile_name="imu_pub">
    <qos>
      <reliability>
        <kind>RELIABLE</kind>
      </reliability>
      <durability>
        <kind>VOLATILE</kind>
      </durability>
    </qos>
    <historyMemoryPolicy>PREALLOCATED</historyMemoryPolicy>
  </data_writer>

  <!-- Fusion output + Heartbeats: reliable -->
  <data_writer profile_name="reliable_pub">
    <qos>
      <reliability>
        <kind>RELIABLE</kind>
      </reliability>
      <durability>
        <kind>VOLATILE</kind>
      </durability>
    </qos>
    <historyMemoryPolicy>PREALLOCATED</historyMemoryPolicy>
  </data_writer>

  <!-- ================================================================
       DataReader QoS profiles — 和 DataWriter 配套
       ================================================================ -->

  <data_reader profile_name="camera_sub">
    <qos>
      <reliability>
        <kind>BEST_EFFORT</kind>
      </reliability>
      <durability>
        <kind>VOLATILE</kind>
      </durability>
    </qos>
    <historyMemoryPolicy>PREALLOCATED</historyMemoryPolicy>
    <propertiesPolicy>
      <properties>
        <property>
          <name>socket_buffer_size</name>
          <value>2097152</value>
        </property>
      </properties>
    </propertiesPolicy>
  </data_reader>

  <data_reader profile_name="reliable_sub">
    <qos>
      <reliability>
        <kind>RELIABLE</kind>
      </reliability>
      <durability>
        <kind>VOLATILE</kind>
      </durability>
    </qos>
    <historyMemoryPolicy>PREALLOCATED</historyMemoryPolicy>
  </data_reader>
</profiles>
